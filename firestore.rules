rules_version = '2';

// 회의록: 읽기는 누구나(팀 열람), 쓰기는 "지정된 관리자 1명"만.
// ⚠️ 관리자를 바꾸면 아래 ADMIN_UID를 새 UID로 교체하고 콘솔에 다시 게시하세요.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'EYkwU0xfP4cfQaWYl8UHqJiTxyt1';
    }

    // 저장되는 문서의 기본 형태·크기 검증 (오염/과대 문서 방지)
    function validMeeting(d) {
      return d.title is string && d.title.size() > 0 && d.title.size() <= 300
        && d.meetingDate is string && d.meetingDate.size() <= 20
        && d.body is string && d.body.size() < 200000
        && d.tags is list && d.tags.size() <= 50
        && d.actionItems is list && d.actionItems.size() <= 500
        && d.attachments is list && d.attachments.size() <= 50;
    }

    match /meetings/{meetingId} {
      allow read: if true;
      allow create, update: if isAdmin() && validMeeting(request.resource.data);
      allow delete: if isAdmin();
    }

    // 그 외 컬렉션은 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
